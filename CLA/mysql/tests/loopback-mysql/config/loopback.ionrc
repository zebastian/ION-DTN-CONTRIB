# ionrc configuration file for the MySQL CLA loopback test.
# command: % ionadmin loopback.ionrc

# Initialization command (command 1): node 1 (as in ipn:1).
1 1 ''

# start ion node
s

# Loopback contact / range (node 1 to itself).
a contact +1 +3600 1 1 100000
a range +1 +3600 1 1 1

# Production / consumption rates.
m production 1000000
m consumption 1000000
