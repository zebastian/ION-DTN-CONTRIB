# bprc for the QUIC CLA loopback test. QUICDUCT/CERT/KEY substituted by dotest.
1
a scheme ipn 'ipnfw' 'ipnadminep'
a endpoint ipn:1.1 q
a endpoint ipn:1.2 q
a protocol quic 1400 100
a induct  quic QUICDUCT 'quiccli -c CERT -k KEY'
a outduct quic QUICDUCT 'quicclo -n -u'
r 'ipnadmin config/loopback_runtime.ipnrc'
s
