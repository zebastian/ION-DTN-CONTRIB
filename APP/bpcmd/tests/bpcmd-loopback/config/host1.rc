## begin ionadmin

# Initialization: node 1, default sdr config.
1 1 ''

# Start ION node.
s

# Single-node loopback contact / range.
a contact +1 +3600 1 1 100000
a range +1 +3600 1 1 1

# Production / consumption rates.
m production 1000000
m consumption 1000000

# Disable congestion forecasting for the test.
m horizon +0
## end ionadmin

## begin bpadmin

1

a scheme ipn 'ipnfw' 'ipnadminep'

# bpcmdd listen endpoints (1.5 default-reply, 1.7 -n) plus the sender
# source endpoints the test cases reply to (1.6, 1.8).
a endpoint ipn:1.0 q
a endpoint ipn:1.5 q
a endpoint ipn:1.6 q
a endpoint ipn:1.7 q
a endpoint ipn:1.8 q

a protocol udp 1400 100
a induct   udp 127.0.0.1:4556 udpcli
a outduct  udp 127.0.0.1:4556 'udpclo 2'

s
## end bpadmin

## begin ipnadmin
a plan 1 udp/127.0.0.1:4556
## end ipnadmin
